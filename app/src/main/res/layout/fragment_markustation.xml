<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="15sp"
    tools:context=".MarkuStationFragment">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/error"
        android:name="ee.mas.integratsioonitarkvara.ErrorFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/markuStationContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textView5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monitori režiim" />

        <Spinner
            android:id="@+id/monitorModeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/monitor_modes_array"
            android:paddingStart="5sp"
            android:paddingTop="20sp"
            android:paddingEnd="5sp"
            android:paddingBottom="20sp" />

        <CheckBox
            android:id="@+id/introCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:onClick="markuStationCheckboxClick"
            android:text="Luba introd" />

        <CheckBox
            android:id="@+id/creepypastaCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:onClick="markuStationCheckboxClick"
            android:text="Creepypasta intro" />

        <CheckBox
            android:id="@+id/legacyCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:onClick="markuStationCheckboxClick"
            android:text="Pärandintro" />

        <CheckBox
            android:id="@+id/specialCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:onClick="markuStationCheckboxClick"
            android:text="Special intro" />
    </LinearLayout>

</LinearLayout>